#!/bin/sh

echo ""
echo "╔════════════════════════════════════════╗"
echo "║     Running pre-push quality checks    ║"
echo "╚════════════════════════════════════════╝"
echo ""

# Track failures
FAILED=0

# Type check
echo "→ Type checking..."
if ! npx tsc --noEmit; then
  echo ""
  echo "❌ TypeScript type check failed."
  echo "   Fix: Review the errors above and update your TypeScript code."
  echo "   Run: npm run typecheck"
  echo ""
  FAILED=1
fi

# Lint
echo ""
echo "→ Linting..."
if ! npm run lint; then
  echo ""
  echo "❌ ESLint found issues."
  echo "   Fix: Review the lint errors above."
  echo "   Run: npm run lint -- --fix  (to auto-fix simple issues)"
  echo ""
  FAILED=1
fi

# Tests
echo ""
echo "→ Running tests..."
if ! npm test; then
  echo ""
  echo "❌ Tests failed."
  echo "   Fix: Review the test failures above."
  echo "   Run: npm run test:watch  (to debug interactively)"
  echo ""
  FAILED=1
fi

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "╔════════════════════════════════════════╗"
  echo "║    Pre-push checks FAILED             ║"
  echo "║  Fix the errors above and try again.  ║"
  echo "╚════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo ""
echo "✅ All checks passed!"
echo ""

# Bump minor version and reset patch to 0 (runs only after checks pass)
export SKIP_VERSION_BUMP=1
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
const [major, minor] = pkg.version.split('.').map(Number);
pkg.version = \`\${major}.\${minor + 1}.0\`;
fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
console.log('Version bumped to', pkg.version);
"
NEW_VERSION=$(node -p "require('./package.json').version")
git add package.json
git commit -m "chore: bump version to $NEW_VERSION"
