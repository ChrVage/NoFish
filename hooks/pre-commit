#!/bin/sh

# Refresh lib/version.json so the in-progress commit's count is recorded in
# the same commit. The commit count is the single source of truth for the
# version shown in dev and prod (read by next.config.ts).
node -e "
const fs = require('fs');
const { execSync } = require('child_process');
const current = parseInt(execSync('git rev-list --count HEAD', { encoding: 'utf8' }).trim(), 10) || 0;
// +1 accounts for the commit currently being created.
const commits = current + 1;
fs.writeFileSync('lib/version.json', JSON.stringify({ commits }, null, 2) + '\n');
console.log('Recorded build', commits, 'in lib/version.json');
"
git add lib/version.json
